# cc-memory 環境変数設定
# このファイルを .env にコピーして値を変更してください。
# すべての項目にデフォルト値があるため、.env がなくてもゼロコンフィグで動作します。

# --- Database ---
# データベースファイルのパス。未指定時は ~/.claude/.claude-code-memory/discussion.db
# 既存の DISCUSSION_DB_PATH もフォールバックとしてサポート（CCM_DB_PATH を優先）
# CCM_DB_PATH=/path/to/discussion.db

# --- Activity ---
# ハートビートのタイムアウト（分）。この時間以内のheartbeatを「活性」と判定する
# CCM_HEARTBEAT_TIMEOUT=20

# --- Active Context 表示 ---
# SessionStart hookで表示するin_progressアクティビティの上限数
# CCM_IN_PROGRESS_LIMIT=3
# SessionStart hookで表示するpendingアクティビティの上限数
# CCM_PENDING_LIMIT=2

# --- Search ---
# 検索結果のrecency boostの減衰率。大きいほど古い記録のスコアが下がる
# CCM_RECENCY_DECAY_RATE=0.0014

# --- Sync Memory ---
# trueにすると /sync-memory のふりかえりセクションをスキップする
# CCM_SYNC_DISABLE_RETROSPECTIVE=false
